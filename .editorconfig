root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# palantir-java-format uses 4-space indentation
[*.java]
indent_style = space
indent_size = 4

[*.xml]
indent_style = space
indent_size = 2

# pom.xml is historically tab-indented; keep just that file on tabs to avoid churn.
[pom.xml]
indent_style = tab

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# Markdown uses trailing spaces for hard line breaks; don't trim them.
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# The generated Windows Maven Wrapper script keeps CRLF.
[*.cmd]
end_of_line = crlf
